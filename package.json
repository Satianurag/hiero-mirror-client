{
  "name": "@satianurag/hiero-mirror-client",
  "version": "0.2.0",
  "description": "Standalone TypeScript client for the Hedera/Hiero Mirror Node REST API",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.mjs",
      "require": "./dist/utils.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "postbuild": "node -e \"const fs=require('fs');const p=require('path');for(const f of['index','utils']){const src=p.join('dist',f+'.d.mts');const dst=p.join('dist',f+'.d.ts');if(fs.existsSync(src)){fs.copyFileSync(src,dst);console.log('Copied '+src+' -> '+dst)}else{console.warn('WARN: '+src+' not found')}}\"",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration/",
    "api-report": "api-extractor run --local --verbose",
    "api-report:ci": "api-extractor run",
    "generate:spec": "curl -o openapi.yml https://testnet.mirrornode.hedera.com/api/v1/docs/openapi.yml",
    "generate:types": "npx openapi-typescript openapi.yml -o src/generated/types.ts",
    "generate": "npm run generate:spec && npm run generate:types",
    "check:drift": "npx openapi-typescript openapi.yml -o src/generated/types.ts --check",
    "docs": "typedoc"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Satianurag/hiero-mirror-client.git"
  },
  "keywords": [
    "hedera",
    "hiero",
    "mirror-node",
    "blockchain",
    "sdk",
    "typescript"
  ],
  "author": "satianurag",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Satianurag/hiero-mirror-client/issues"
  },
  "homepage": "https://github.com/Satianurag/hiero-mirror-client#readme",
  "dependencies": {
    "lossless-json": "^4.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@microsoft/api-extractor": "^7.52.8",
    "@vitest/coverage-v8": "^4.0.18",
    "openapi-typescript": "^7.6.1",
    "tsdown": "^0.12.5",
    "typedoc": "^0.28.17",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
